# Google AI Studio API Key (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# Path to your Firebase service account private key JSON file (absolute or relative to backend/)
FIREBASE_SERVICE_ACCOUNT_KEY=app/core/serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Server configuration
PORT=8080
HOST=0.0.0.0
